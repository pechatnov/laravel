# Имя проекта в Docker Compose
COMPOSE_PROJECT_NAME=laravel

# PHP version settings. Allowed values are: php56, php71, php73, php74, php80, php81, php82, php83, php84
PHP_VERSION=php84

# Web server type. Allowed value is apache or nginx.
WEB_SERVER_TYPE=nginx

# MySQL settings. Allowed value is mysql or percona.
DB_SERVER_TYPE=mysql
MYSQL_DATABASE=laravel
MYSQL_USER=laravel
MYSQL_PASSWORD=123
MYSQL_ROOT_PASSWORD=123

# Порт MySQL на хосте (для клиентов с машины). Внутри сети Docker всегда db:3306.
# Если локальный MySQL уже слушает 3306 — поставь 3307 или другой свободный.
MYSQL_PUBLISH_PORT=3307

# Network
INTERFACE=0.0.0.0

# Код Laravel (composer.json, app/, public/) — монтируется в /var/www/html
SITE_PATH=./www
